# Root gitignore for promptwars_3

# Secrets and environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
backend/.env

# Databases
backend/carbon.db
*.db
*.sqlite3

# Python Virtual Environments & Packages
backend/venv/
backend/.venv/
venv/
.venv/
env/

# Python caching
__pycache__/
*.pyc
*.pyo
*.pyd
backend/__pycache__/
backend/**/*.pyc

# Node / Frontend dependencies and builds
node_modules/
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.tsbuildinfo
frontend/next-env.d.ts

# Misc OS & Editor files
.DS_Store
Thumbs.db
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
